---
/* 
  TurboQuant Global Navbar — v4.3
  Multilingual Convertible & Voice Search Enabled
*/

import { TRANSLATIONS } from "../data/translations";

const { activePage = "home", lang = "en" } = Astro.props;
const t = TRANSLATIONS[lang] || TRANSLATIONS.en;

const alternateLanguages = [
  { code: "en", label: "English", flag: "🇺🇸" },
  { code: "hi", label: "हिन्दी", flag: "🇮🇳" },
  { code: "ml", label: "മലയാളം", flag: "🇮🇳" },
  { code: "es", label: "Español", flag: "🇪🇸" },
  { code: "ja", label: "日本語", flag: "🇯🇵" },
  { code: "zh", label: "中文", flag: "🇨🇳" },
  { code: "de", label: "Deutsch", flag: "🇩🇪" },
  { code: "fr", label: "Français", flag: "🇫🇷" }
];
---

<nav class="nav">
  <div class="nav-inner">
    <div class="nav-left">
      <a href="/" class="nav-logo">
        <div class="logo-mark">TQ</div>
        <span class="logo-text">Turbo<span>Quant</span> Network</span>
      </a>
      
      <ul class="nav-links">
        <li><a href="/ai-agent-platform" class={activePage === "platform" ? "active" : ""}>{t.nav.platform}</a></li>
        <li><a href="/ai-kanban-board" class={activePage === "kanban" ? "active" : ""}>{t.nav.kanban}</a></li>
        <li><a href="/ai-automation-system" class={activePage === "automation" ? "active" : ""}>{t.nav.automation}</a></li>
        <li><a href="/blog" class={activePage === "blog" ? "active" : ""}>{t.nav.library}</a></li>
        <li><a href="/about" class={activePage === "about" ? "active" : ""}>{t.nav.about}</a></li>
      </ul>
    </div>

    <div class="nav-right">
      <!-- Multilingual Switcher -->
      <div class="lang-switcher">
        <button class="lang-btn" id="lang-btn">
          <span>🌐</span> <span id="current-lang-code">{lang.toUpperCase()}</span>
        </button>
        <div class="lang-dropdown" id="lang-dropdown">
          {alternateLanguages.map(l => (
            <button class="lang-item" data-lang={l.code}>
              <span class="flag">{l.flag}</span>
              <span class="label">{l.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Voice Assistant Trigger -->
      <button class="voice-btn" id="voice-trigger" title="Ask Voice Assistant">
        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
      </button>

      <a href="/build-ai-agent" class="nav-cta">{t.nav.cta}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    height: 72px; background: rgba(4,6,14,0.85); backdrop-filter: blur(25px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-inner {
    max-width: 1400px; margin: 0 auto; height: 100%; padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-left { display: flex; align-items: center; gap: 3rem; }
  
  .nav-logo { text-decoration: none; display: flex; align-items: center; gap: 0.75rem; }
  .logo-mark { 
    width: 38px; height: 38px; background: linear-gradient(135deg, var(--accent), var(--accent2)); 
    border-radius: 10px; display: flex; align-items: center; justify-content: center; 
    font-family: var(--font-display); font-weight: 800; color: #000; font-size: 0.9rem;
  }
  .logo-text { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--text); }
  .logo-text span { color: var(--accent); }

  .nav-links { list-style: none; display: flex; gap: 1.5rem; }
  .nav-links a { 
    text-decoration: none; color: var(--text-2); font-size: 0.9rem; font-weight: 500; 
    transition: color 0.3s; 
  }
  .nav-links a:hover, .nav-links a.active { color: var(--accent); }

  .nav-right { display: flex; align-items: center; gap: 1.5rem; }
  
  .lang-switcher { position: relative; }
  .lang-btn { 
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); 
    padding: 0.5rem 0.8rem; border-radius: 8px; color: var(--text); 
    display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; cursor: pointer; transition: all 0.3s;
  }
  .lang-btn:hover { background: rgba(255,255,255,0.1); border-color: var(--accent); }
  
  .lang-dropdown { 
    position: absolute; top: calc(100% + 10px); right: 0; background: var(--bg); 
    border: 1px solid var(--glass-border); border-radius: 12px; width: 180px; 
    padding: 0.5rem; display: none; box-shadow: 0 20px 60px rgba(0,0,0,0.6); animation: fadeDown 0.3s ease both;
  }
  .lang-dropdown.show { display: block; }
  @keyframes fadeDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

  .lang-item { 
    width: 100%; background: none; border: none; padding: 0.6rem 0.8rem; 
    display: flex; align-items: center; gap: 0.75rem; color: var(--text-2); 
    cursor: pointer; border-radius: 6px; font-size: 0.85rem; transition: background 0.2s;
  }
  .lang-item:hover { background: rgba(0,229,255,0.08); color: var(--accent); }
  .flag { font-size: 1.1rem; }

  .voice-btn { background: none; border: none; color: var(--text-2); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; transition: all 0.3s; }
  .voice-btn:hover { background: rgba(0,229,255,0.1); color: var(--accent); transform: scale(1.1); }
  .voice-btn svg { width: 20px; height: 20px; }

  .nav-cta { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #000; padding: 0.65rem 1.4rem; border-radius: 10px; text-decoration: none; font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; transition: opacity 0.3s; }
  .nav-cta:hover { opacity: 0.85; }

  @media (max-width: 1000px) { .nav-links { display: none; } }
</style>

<script is:inline>
  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  const langCodeEl = document.getElementById('current-lang-code');

  if(langBtn){
    langBtn.onclick = (e) => { e.stopPropagation(); langDropdown.classList.toggle('show'); };
  }

  document.onclick = (e) => { if(!e.target.closest('.lang-switcher')) langDropdown?.classList.remove('show'); };

  document.querySelectorAll('.lang-item').forEach(item => {
    item.onclick = function() {
      const lang = this.getAttribute('data-lang');
      langCodeEl.innerText = lang.toUpperCase();
      langDropdown.classList.remove('show');
      // Set global lang and reload for static generation demo or store in session
      document.documentElement.lang = lang;
      const url = new URL(window.location);
      url.searchParams.set('lang', lang);
      window.location.href = url.toString();
    };
  });

  document.getElementById('voice-trigger')?.addEventListener('click', () => {
     // Localized Voice Trigger
     const currentLang = document.documentElement.lang || 'en';
     const t = window.TURBOQUANT_TRANSLATIONS?.[currentLang]?.voice || { ready: "TurboQuant Voice Ready" };
     alert(t.ready + "\nListening in " + currentLang.toUpperCase() + "...");
  });
</script>
