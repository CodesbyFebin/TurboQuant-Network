---
/* 
  TurboQuant Hero Component — v4.3
  Multilingual Convertible & Voice SEO Enabled
*/
import { TRANSLATIONS } from "../data/translations";

const { lang = "en" } = Astro.props;
const t = TRANSLATIONS[lang] || TRANSLATIONS.en;
---

<section class="hero" aria-labelledby="hero-h1">
  <div class="hero-orbs" aria-hidden="true">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
  </div>
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-badge" role="status" id="speakable-hero">
      <span class="dot" aria-hidden="true"></span>
      {t.hero.tag}
    </div>
    <h1 class="hero-h1" id="hero-h1" set:html={t.hero.h1}>
    </h1>
    <p class="hero-sub" set:html={t.hero.sub}>
    </p>
    <div class="hero-actions">
      <a href="/build-ai-agent" class="btn-primary">{t.hero.cta_primary}</a>
      <a href="/ai-agent-platform" class="btn-ghost">{t.nav.platform}</a>
      <a href="/blog" class="btn-ghost">{t.nav.library}</a>
    </div>
    <div class="hero-stats" role="region" aria-label="Platform statistics">
      <div class="stat-item">
        <div class="stat-val">50K+</div><div class="stat-lbl">Developers</div>
      </div>
      <div class="stat-item">
        <div class="stat-val">2.8M+</div><div class="stat-lbl">Agent Runs</div>
      </div>
      <div class="stat-item">
        <div class="stat-val">4.9★</div><div class="stat-lbl">Rating</div>
      </div>
      <div class="stat-item">
        <div class="stat-val">99.9%</div><div class="stat-lbl">Uptime</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 80px 24px 60px;
  }
  .hero-orbs {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
  }
  .orb1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -100px;
    background: var(--hero-g1);
  }
  .orb2 {
    width: 500px;
    height: 500px;
    bottom: -100px;
    left: -150px;
    background: var(--hero-g2);
    animation-delay: -4s;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse at center,
      black 10%,
      transparent 75%
    );
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
    width: 100%;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(16, 245, 132, 0.08);
    border: 1px solid rgba(16, 245, 132, 0.22);
    border-radius: 100px;
    padding: 5px 16px;
    font-family: var(--font-mono);
    font-size: 0.71rem;
    color: var(--accent);
    margin-bottom: 28px;
    animation: fadeUp 0.5s ease both;
    letter-spacing: 0.08em;
  }
  .hero-badge .dot {
    width: 7px;
    height: 7px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 1.8s infinite;
    flex-shrink: 0;
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.4rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.04em;
    background: linear-gradient(
      135deg,
      var(--text) 0%,
      var(--accent2) 35%,
      var(--accent) 65%,
      var(--text) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 300% 300%;
    animation:
      fadeUp 0.6s 0.1s ease both,
      gradShift 6s ease-in-out infinite;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: clamp(0.94rem, 2.2vw, 1.22rem);
    color: var(--text2);
    max-width: 680px;
    margin: 0 auto 36px;
    line-height: 1.78;
    animation: fadeUp 0.6s 0.2s ease both;
    font-weight: 300;
  }
  .hero-sub strong {
    color: var(--accent);
    font-weight: 600;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.3s ease both;
    margin-bottom: 52px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #020408;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 13px 26px;
    border-radius: 10px;
    border: none;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    box-shadow: 0 0 28px var(--glow-g);
    cursor: pointer;
    letter-spacing: 0.01em;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 50px var(--glow-g);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border2);
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 13px 26px;
    border-radius: 10px;
    transition:
      border-color 0.2s,
      background 0.2s;
    cursor: pointer;
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    background: var(--glow-g);
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(20px);
    animation: fadeUp 0.6s 0.5s ease both;
    max-width: 680px;
    margin: 0 auto;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 18px 32px;
    border-right: 1px solid var(--border);
    flex: 1;
    min-width: 110px;
  }
  .stat-item:last-child {
    border-right: none;
  }
  .stat-val {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-lbl {
    font-size: 0.67rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    margin-top: 3px;
  }
</style>
